{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021"],
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "paths": {
      "./*": ["./*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
